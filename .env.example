# Configurações Gerais
PROJECT_NAME="BellaZap"
API_V1_STR="/api/v1"
SECRET_KEY="troque_isso_por_um_segredo_forte_em_producao"
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM="HS256"

# Banco de Dados (PostgreSQL / Supabase)
# Formato: postgresql+asyncpg://usuario:senha@host:porta/database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/bellazap"

# Redis (Celery / Cache)
REDIS_URL="redis://localhost:6379/0"

# IA & Agentes (Estratégia Híbrida)
# Opções para LLM_STRATEGY: 'local' ou 'cloud'
LLM_STRATEGY="local"
LOCAL_LLM_MODEL=qwen2.5:3b
CLOUD_LLM_MODEL="gpt-4-turbo-preview"
OLLAMA_BASE_URL="http://localhost:11434"
OPENAI_API_KEY="sk-..."

# Pagamentos (Dual-Provider)
ASAAS_API_KEY="SUA_API_KEY_ASAAS_AQUI"
ASAAS_ENV="sandbox" # ou production
ABACATE_API_KEY="SUA_API_KEY_ABACATE_AQUI"
ABACATE_ENV="sandbox" # ou production

# WhatsApp (Evolution API)
# Aponte para onde sua Evolution API está rodando
WHATSAPP_API_URL="http://localhost:8080"
WHATSAPP_GLOBAL_API_KEY="42ha9631-411a-4286-932d-20d43c7b64a2"
